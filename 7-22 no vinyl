function closeQuoteModal(){
  g("quote-modal").style.display="none";
}
function submitQuoteModal(){
  const name=(g("qm-name").value||"").trim();
  const email=(g("qm-email").value||"").trim();
  const phone=(g("qm-phone").value||"").trim();
  const notes=(g("qm-notes")&&g("qm-notes").value||"").trim();
  if(!name){toast("Please enter your name.");g("qm-name").focus();return;}
  if(!email||!email.includes("@")){toast("Please enter a valid email.");g("qm-email").focus();return;}
  const qn=qNum();
  const boatLabel=S.year+" "+S.make+" "+S.model;
  const matLabel=S.matType==="berber"?"Snap-In Berber Carpet":S.matType==="vinyl"?"DuraVinyl Marine Flooring":"Snap-In Marine Carpet";
  const colorLabel=S.color||"";
  const pieces=(function(){var ps=Object.keys(S.sel||{});return ps.length?ps.join(", "):"";})();
  const priceVal=(typeof S.price==="number"?S.price.toFixed(2):"");
  const modalEl=document.getElementById("quote-modal");
  const btn=modalEl?modalEl.querySelector("button[onclick*=\"submitQuoteModal\"]"):null;
  if(btn){btn.disabled=true;btn.dataset.orig=btn.textContent;btn.textContent="Sending...";}
  const restore=function(){if(btn){btn.disabled=false;btn.textContent=btn.dataset.orig||"Send My Quote Request";}};
  const fd=new FormData();
  fd.append("action","bc_submit_quote");
  fd.append("name",name);
  fd.append("email",email);
  fd.append("phone",phone);
  fd.append("notes",notes);
  fd.append("quote_num",qn);
  fd.append("boat_year",S.year||"");
  fd.append("boat_make",S.make||"");
  fd.append("boat_model",S.model||"");
  fd.append("color",colorLabel);
  fd.append("material",matLabel);
  fd.append("price",priceVal);
  fd.append("pieces",pieces);
  fd.append("boat_label",boatLabel);
  fetch("/wp-admin/admin-ajax.php",{method:"POST",body:fd,credentials:"same-origin"})
    .then(function(r){return r.json();})
    .then(function(res){
      if(res&&res.success){
        ["qm-name","qm-email","qm-phone","qm-notes"].forEach(function(id){var el=g(id);if(el&&el.parentElement)el.parentElement.style.display="none";});
        if(btn)btn.style.display="none";
        const msg=g("qm-msg");
        if(msg){msg.innerHTML="&#10003; Thank you! Your quote request (Quote #<strong>"+qn+"</strong>) has been submitted. Check your email for confirmation.";msg.style.display="block";}
        setTimeout(function(){closeQuoteModal();},6000);
      }else{restore();toast("Sorry, something went wrong submitting your quote. Please try again or call us.");}
    })
    .catch(function(){restore();toast("Sorry, something went wrong submitting your quote. Please try again or call us.");});
}
function fallbackCopy(txt){
  const ta=document.createElement("textarea");
  ta.value=txt;ta.style.position="fixed";ta.style.opacity="0";
  document.body.appendChild(ta);ta.select();
  try{document.execCommand("copy");}catch(e){}
  document.body.removeChild(ta);
}

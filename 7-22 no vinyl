      <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;">Phone</label>
      <input type="tel" id="qm-phone" placeholder="(555) 555-5555" style="width:100%;padding:9px 12px;border:1px solid #ccc;border-radius:6px;font-size:14px;box-sizing:border-box;">
    </div>
    <div style="margin-bottom:18px;">
      <label style="display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;">Notes</label>
      <textarea id="qm-notes" placeholder="Any special requests or questions..." rows="3" style="width:100%;padding:9px 12px;border:1px solid #ccc;border-radius:6px;font-size:14px;box-sizing:border-box;resize:vertical;"></textarea>
    </div>
    <button onclick="submitQuoteModal()" style="width:100%;padding:12px;background:#1a2e44;color:#fff;border:none;border-radius:7px;font-size:15px;font-weight:600;cursor:pointer;">Send My Quote Request</button>
  </div>
</div>

<script>
(function(){
  var box     = document.getElementById('nopat');
  var divider = document.getElementById('nopat-divider');
  var make    = document.getElementById('make');
  var model   = document.getElementById('model');
  var year    = document.getElementById('year');
  if(!box || !make) return;

  var revealed = false, modelTimer = null, idleTimer = null;

  function track(evt, data){
    try{
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push(Object.assign({event: evt}, data||{}));
      if(typeof window.gtag === 'function'){ window.gtag('event', evt, data||{}); }
    }catch(e){}
  }
  function reveal(reason){
    if(revealed) return;
    revealed = true;
    box.classList.add('is-visible');
    track('nopat_shown', {reason: reason});
  }
  function hide(reason){
    box.classList.remove('is-visible');
    if(divider){ divider.style.display = 'none'; }
    clearTimeout(modelTimer); clearTimeout(idleTimer);
    if(revealed){ track('nopat_hidden', {reason: reason}); }
    revealed = false;
  }

  make.addEventListener('change', function(){
    track('step1_make_selected', {make: make.value});
    clearTimeout(modelTimer); clearTimeout(idleTimer);
    if(make.value === 'other'){ reveal('other_selected'); return; }
    if(make.value){
      modelTimer = setTimeout(function(){ if(!model.value) reveal('make_no_model'); }, 6000);
    } else { hide('make_cleared'); }
  });
  model.addEventListener('change', function(){
    if(model.value){ track('step1_model_selected', {model: model.value}); hide('model_selected'); }
  });
  if(year){ year.addEventListener('change', function(){ if(year.value) track('step1_year_selected', {year: year.value}); }); }

  function armIdle(){
    clearTimeout(idleTimer);
    idleTimer = setTimeout(function(){ if(!(model && model.value)) reveal('inactivity'); }, 18000);
  }
  ['click','change','keydown'].forEach(function(ev){
    document.addEventListener(ev, function(){ if(!revealed) armIdle(); }, true);
  });
  armIdle();
})();
</script>
</body>
</html>
